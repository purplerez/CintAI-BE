APP_NAME="EduCode Studio"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=educode_studio
DB_USERNAME=root
DB_PASSWORD=

# Queue: use 'redis' in production, 'database' for local dev
QUEUE_CONNECTION=database

# Cache
CACHE_STORE=database
SESSION_DRIVER=database

# Redis (for production queue)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@educode.test"
MAIL_FROM_NAME="${APP_NAME}"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

# CORS
FRONTEND_URL=http://localhost:5173

# OpenAI (for AI Code Review)
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Docker Sandbox
SANDBOX_IMAGE=educode/sandbox:latest

# Filesystem
FILESYSTEM_DISK=local
